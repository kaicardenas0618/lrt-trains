{
  "name": "lrt-trains",
  "version": "v1.0.0",
  "description": "A train pack containing LRT trains from around the world for Subway Builder.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently --success first -k -n build,game -c blue,green \"vite build --watch\" \"tsx scripts/run.ts\"",
    "dev:link": "tsx scripts/link.ts",
    "dev:unlink": "tsx scripts/link.ts --unlink",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "subway-builder",
    "mod"
  ],
  "author": "kaicardenas0618",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.9",
    "concurrently": "^9.2.1",
    "maplibre-gl": "^5.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-static-copy": "^3.0.0"
  },
  "dependencies": {
    "fs": "^0.0.1-security",
    "papaparse": "^5.5.3",
    "pnpm": "^10.30.3",
    "react-select": "^5.10.2",
    "react-select-search": "^4.1.9"
  }
}
